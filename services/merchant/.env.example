# ── Server ──────────────────────────────────────
# Gateway will route to this gRPC port
GRPC_PORT=9092

# ── Database ────────────────────────────────────
# Ensure strict database isolation (no sharing with auth)
POSTGRES_USER=merchant_user
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=moneymate_merchant

# ── Environment ─────────────────────────────────
ENVIRONMENT=dev