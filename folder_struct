└── 📁services
    │
    └── 📁auth      ← auth microservice, owns all identity + credential logic
    |    │
    |    └── 📁cmd
    |    │   └── main.go                 ← entry point, wires all dependencies together (db, redis, repos, usecases, handlers), starts HTTP + gRPC servers
    |    │
    |    └── 📁config
    |    │   └── config.go   ← auth-specific Config struct, loads env vars (DB url, redis url, jwt secret, argon2 params, ports)
    |    │
    |    └── 📁internal     ← everything here is private to auth-svc, Go compiler prevents other services importing this
    |    │   │
    |    │   └── 📁adapter   ← implementations of domain interfaces, all external I/O lives here (postgres, redis, grpc)
    |    │   │   │
    |    │   │   └── 📁grpc
    |    │   │   │   └── server.go  ← implements the gRPC server interface gen from auth.proto, calls usecases, returns proto res
    |    │   │   │
    |    │   │   └── 📁postgres
    |    │   │   │   └── 📁queries       ← SQLC generated Go code, never edit manually, regenerated by running sqlc generate
    |    │   │   │   ├── db.go       ← Connect() func, creates and returns *pgxpool.Pool using auth_user DSN pointed at auth schema
    |    │   │   │   └── user_repo.go    ← implements UserRepository interface, wraps SQLC queries, all DB operations for users table
    |    │   │   │
    |    │   │   └── 📁redis
    |    │   │       ├── client.go       ← Connect() func, creates and returns *redis.Client using redis url from config
    |    │   │       └── token_store.go  ← stores/checks transaction tokens (60s TTL), JTI blacklist, OTP rate limiting, PIN lockout 
    |    │   │
    |    │   └── 📁domain      ← pure Go, zero external imports, defines what auth-svc owns and what operations exist on it
    |    │   │   └── user.go  ← User struct, UserRepository interface (CreateUser, FindByEmail, FindByID etc), domain errors (ErrUserNotFound, ErrInvalidCredentials)
    |    │   │
    |    │   └── 📁transport    ← how the outside world talks to this service, HTTP for clients, gRPC for internal services
    |    │   │   │
    |    │   │   └── 📁grpc
    |    │   │   │   └── router.go  ← starts gRPC listener on GRPC_PORT, registers gRPC server, runs alongside HTTP server
    |    │   │   │
    |    │   │   └── 📁http
    |    │   │       ├── auth_handler.go ← HTTP handlers for Register, Login, Logout, RefreshToken, parses request, calls usecase, returns response
    |    │   │       └── routes.go       ← creates fiber app, registers all routes (/auth/register /auth/login etc), applies middleware
    |    │   │
    |    │   └── 📁usecases              ← business logic only, no HTTP or DB concepts, orchestrates domain + adapter calls
    |    │       └── auth_usecase.go     ← Register() Login() Logout() RefreshToken() VerifyPIN() IssueTransactionToken(), calls repos and jwt package
    |    │
    |    └── 📁migrations                ← auth schema SQL files only, run by golang-migrate against auth schema on startup
    |    │   ├── 000001_create_users.up.sql    ← creates auth.users table with all columns
    |    │   └── 000001_create_users.down.sql  ← drops auth.users table, used for rollback
    |    │
    |    └── 📁sqlc
    |    │   └── 📁queries
    |    │   │   └── users.sql           ← raw SQL queries with SQLC annotations (-- name: CreateUser :one), SQLC reads these to generate Go code
    |    │   └── sqlc.yaml               ← SQLC config, points to queries folder, sets output path to adapter/postgres/queries, sets schema
    |    │
    |    └── 📁tmp
    |    │   └── main                    ← Air live reload binary output, gitignored, rebuilt automatically on file change during dev
    |    │
    |    ├── .air.toml                   ← Air live reload config, watches .go files, rebuilds to tmp/main on change
    |    ├── .env                        ← actual secrets for local dev (DB url, redis url, jwt secret), never committed
    |    ├── .env.example                ← template with empty values, committed, teammates copy to .env and fill in
    |    ├── Dockerfile                  ← multi stage build, stage 1 compiles Go binary, stage 2 copies binary into minimal image
    |    └── go.mod                      ← auth-svc module definition (module github.com/org/moneymate/auth-svc), lists dependencies
    │
    └── 📁gateway     ← gateway microservice, single entry point for all clients, handles routing + auth + rate limiting
        │
        └── 📁cmd
        │   └── main.go                 ← entry point, wires config + redis + grpc clients + middleware + router, starts HTTP server
        │
        └── 📁config
        │   └── config.go               ← gateway-specific Config struct (Port, AuthServiceURL, RedisURL, JWTSecret, Environment)
        │
        └── 📁internal                  ← private to gateway-svc only
        │   │
        │   └── 📁middlewares
        │   │   └── jwt.go              ← Fiber middleware, extracts JWT from Authorization header, validates signature locally, puts claims into fiber context, rejects invalid tokens before request reaches any service
        │   │
        │   └── 📁proxy
        │   │   └── auth_client.go      ← gRPC CLIENT for auth-svc, holds connection to auth-svc:9091, exposes methods gate
        way needs (ValidateToken, GetUserClaims)
        │   │
        │   └── 📁transport
        │       └── 📁http
        │           └── router.go       ← creates fiber app, mounts jwt middleware + rate limit middleware, registers proxy routes that forward to downstream services
        │
        └── 📁tmp
        │   └── main                    ← Air live reload binary output, gitignored
        │
        ├── .air.toml                   ← Air live reload config for gateway
        ├── .env                        ← gateway local secrets (jwt secret, auth service url, redis url), never committed
        ├── .env.example                ← template for gateway env vars, committed
        ├── Dockerfile                  ← multi stage build for gateway binary
        ├── go.mod                      ← gateway module definition (module github.com/org/moneymate/gateway-svc)
        └── go.sum                      ← dependency checksums, auto managed by Go tooling, always committed